entrypoint = "index.js"
modules = ["nodejs-20", "postgresql-16"]
hidden = [".config", "package-lock.json"]

[gitHubImport]
requiredFiles = [".replit", "replit.nix", "package.json", "package-lock.json"]

[nix]
channel = "stable-24_11"
packages = ["jdk", "maven"]

[deployment]
run = ["node", "src/index.js"]
deploymentTarget = "vm"
ignorePorts = false

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Dota2 Inhouse Bot"

[[workflows.workflow]]
name = "Dota2 Inhouse Bot"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node src/index.js"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
SHEET_ID = "1EjFnAnEkDkbgh4gSCmP2xwTZiAlUDsCCHLsrLShhAcE"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5600
externalPort = 80

[[ports]]
localPort = 9999
externalPort = 3001
